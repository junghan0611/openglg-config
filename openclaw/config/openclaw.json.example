{
  "agents": {
    "defaults": {
      "workspace": "/home/node/.openclaw/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 2,
      "subagents": {
        "maxConcurrent": 4
      }
    },
    "list": [
      {
        "id": "main",
        "model": "pi-shell-acp/gpt-5.4"
      }
    ]
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  },
  "channels": {
    "telegram": {
      "enabled": false,
      "botToken": "<TELEGRAM_BOT_TOKEN>",
      "dmPolicy": "pairing",
      "streamMode": "partial",
      "accounts": {
        "default": {
          "enabled": false,
          "botToken": "<TELEGRAM_BOT_TOKEN>",
          "dmPolicy": "pairing",
          "streamMode": "partial"
        }
      }
    },
    "mattermost": {
      "enabled": false,
      "botToken": "<MATTERMOST_BOT_TOKEN>",
      "baseUrl": "<MATTERMOST_BASE_URL>",
      "dmPolicy": "pairing"
    }
  },
  "session": {
    "dmScope": "per-account-channel-peer"
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "<GATEWAY_TOKEN>"
    }
  },
  "plugins": {
    "allow": ["pi-shell-acp"],
    "entries": {
      "pi-shell-acp": {
        "enabled": true,
        "config": {
          "piBinaryPath": "pi",
          "spawnTimeoutSeconds": 60
        }
      }
    }
  }
}
