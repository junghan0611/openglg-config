# OpenClaw public template settings
# Copy to .env, then fill values: cp .env.example .env

# ===== Gateway =====
# Generate with: openssl rand -hex 24
GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PORT=18789

# Optional local host directory mounted at /home/node/workspace.
# Keep this public-safe; do not point at private repos in committed files.
HOST_WORKSPACE_PATH=./workspace

# ===== Telegram Bot =====
# Optional. Create at @BotFather -> /newbot.
TELEGRAM_BOT_TOKEN=

# ===== Mattermost =====
# Optional. Leave empty unless you enable the Mattermost channel in openclaw.json.
MATTERMOST_BOT_TOKEN=
MATTERMOST_BASE_URL=https://chat.example.com

# ===== Backend API keys / OAuth alternatives =====
# Public default is in-container login with named volumes for Claude/Codex/Gemini.
# Set GEMINI_API_KEY only if you choose API-key auth instead of `gemini` OAuth login.
GEMINI_API_KEY=

# Optional emacs skill socket. Requires a matching bind mount in docker-compose.override.yml.
PI_EMACS_AGENT_SOCKET=/run/emacs/server
