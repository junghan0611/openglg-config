# Cloudflare Tunnel — environment
#
# Real .env is gitignored. Operators usually keep this in the root .env and
# symlink it here (.env -> ../.env).

# Tunnel token for THIS host's tunnel.
# Cloudflare dashboard → Zero Trust → Networks → Tunnels → (your tunnel) → token.
# One hostname maps to exactly one tunnel, so a host taking over a hostname needs
# its own tunnel (re-point the hostname to it in the dashboard).
# NEVER commit the real token. If it leaks, rotate it in the dashboard immediately.
TUNNEL_TOKEN=
