# Caddy + Authelia (path 기반 라우팅)
# Copy to Caddyfile and replace DOMAIN with your domain
# cp Caddyfile.template Caddyfile

(authelia) {
	forward_auth authelia:9091 {
		uri /authelia/api/authz/forward-auth
		copy_headers Remote-User Remote-Groups Remote-Email Remote-Name
	}
}

DOMAIN {

	# === Authelia portal + API ===
	handle /authelia/* {
		reverse_proxy authelia:9091
	}
	handle /authelia {
		redir /authelia/ 302
	}

	# === 공개 서비스 (인증 불필요) ===

	# / → Homer 대시보드
	@homer path / /assets/* /icons/* /manifest.json /logo.png /resources/*
	handle @homer {
		reverse_proxy homer:8080
	}

	# /remark42 → Remark42 댓글
	handle_path /remark42/* {
		reverse_proxy remark42:8080
	}

	# /umami → Umami analytics
	handle_path /umami/* {
		reverse_proxy umami:3000
	}

	# === 인증 필요 서비스 ===
	# route로 forward_auth → strip → proxy 순서 보장

	# /metabase → Metabase
	handle /metabase/* {
		route {
			import authelia
			uri strip_prefix /metabase
			reverse_proxy metabase:3000
		}
	}

	# /openclaw → OpenClaw AI
	handle /openclaw/* {
		route {
			import authelia
			uri strip_prefix /openclaw
			reverse_proxy openclaw-gateway:18789
		}
	}

	# /mattermost API/WebSocket/hooks/plugins — Mattermost 자체 인증
	# (모바일앱, 외부 webhook, 봇 API 가 Authelia 쿠키 없이 접근하려면 필요)
	handle /mattermost/api/* {
		reverse_proxy mattermost:8065
	}
	handle /mattermost/plugins/* {
		reverse_proxy mattermost:8065
	}
	handle /mattermost/hooks/* {
		reverse_proxy mattermost:8065
	}
	handle /mattermost/oauth/* {
		reverse_proxy mattermost:8065
	}

	# /mattermost 웹 UI — Authelia 게이트 (SiteURL 에 prefix 포함, strip 불필요)
	handle /mattermost/* {
		route {
			import authelia
			reverse_proxy mattermost:8065
		}
	}
	handle /mattermost {
		redir /mattermost/ 302
	}

	# 기본: 인증 필요
	handle {
		import authelia
		reverse_proxy homer:8080
	}
}
