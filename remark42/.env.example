# Remark42 설정
# cp .env.example .env 후 값 채우기

# Core
REMARK_URL=https://comments.example.com
SECRET=<openssl rand -hex 32>
SITE=garden
ALLOWED_HOSTS=comments.example.com,garden.example.com

# GitHub OAuth
# https://github.com/settings/developers → New OAuth App
# Callback URL: https://comments.example.com/auth/github/callback
AUTH_GITHUB_CID=
AUTH_GITHUB_CSEC=

# Google OAuth
# https://console.cloud.google.com/apis/credentials
# Redirect URI: https://comments.example.com/auth/google/callback
AUTH_GOOGLE_CID=
AUTH_GOOGLE_CSEC=

# Anonymous 댓글 허용
AUTH_ANON=true

# Admin
ADMIN_SHARED_ID=
ADMIN_SHARED_EMAIL=you@example.com
