# PostgreSQL (shared) — environment variables
#
# Real .env lives next to docker-compose.yml and is gitignored.
# The shared postgres container hosts databases for Metabase and Mattermost;
# both per-DB passwords are needed at container init time.

# Superuser password for the shared postgres instance.
# Generate: openssl rand -hex 16
POSTGRES_PASSWORD=

# Per-application database passwords (provisioned by postgres init scripts).
# Must match the same variables in metabase/.env and mattermost/.env.
METABASE_DB_PASSWORD=
MATTERMOST_DB_PASSWORD=

# Optional — override docker-data location (default ~/docker-data).
# DATA_DIR=/var/lib/openglg
