# Metabase — environment variables
#
# Real .env lives next to docker-compose.yml and is gitignored.
# Most operators keep these values centralized in the root .env and copy
# (or symlink) this file there; either pattern works because Docker Compose
# reads only the local .env in its own directory.

# Public hostname for metabase, exposed via Cloudflare Tunnel (see cloudflare-tunnel/).
# Map this hostname to http://metabase:3000 in the Cloudflare dashboard.
METABASE_HOSTNAME=metabase.example.com

# PostgreSQL password for the metabase database (created by postgres service).
# Generate: openssl rand -hex 16
METABASE_DB_PASSWORD=

# Metabase application secret — encrypts saved credentials and session keys.
# Generate: openssl rand -hex 32   (minimum 16 chars; do not reuse across instances)
METABASE_SECRET_KEY=

# Optional — override docker-data location (default ~/docker-data).
# DATA_DIR=/var/lib/openglg
