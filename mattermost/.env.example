# Mattermost 설정
# cp .env.example .env 후 값 채우기

# Domain (Caddy에서 사용)
DOMAIN=example.com

# PostgreSQL (Mattermost 전용 DB)
# 생성: openssl rand -hex 16
POSTGRES_PASSWORD=

# OpenClaw 인터랙티브 버튼 콜백 대상 (Mattermost SSRF 허용목록에 추가됨).
# 버튼(승인 게이트) 미사용 시 비워둠 → 동작 변화 없음.
# host-native OpenClaw: 172.18.0.1 (브리지 게이트웨이) / dockerized: openclaw-gateway
OPENCLAW_CALLBACK_HOST=
