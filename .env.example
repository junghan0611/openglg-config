# oracle-selfhost 전역 설정
# .env로 복사 후 값 채우기: cp .env.example .env

# ===== 도메인 =====
DOMAIN=example.com
GARDEN_HOST=garden.example.com
COMMENTS_HOST=comments.example.com
ANALYTICS_HOST=analytics.example.com

# ===== 이메일 (Let's Encrypt 알림용) =====
ACME_EMAIL=you@example.com

# ===== Remark42 =====
REMARK42_SECRET=<openssl rand -hex 32>
REMARK42_SITE=garden
REMARK42_ALLOWED_HOSTS=comments.example.com,garden.example.com

# GitHub OAuth (https://github.com/settings/developers)
# Callback: https://comments.example.com/auth/github/callback
REMARK42_GITHUB_CID=
REMARK42_GITHUB_CSEC=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Redirect: https://comments.example.com/auth/google/callback
REMARK42_GOOGLE_CID=
REMARK42_GOOGLE_CSEC=

# Remark42 Admin
REMARK42_ADMIN_SHARED_ID=
REMARK42_ADMIN_EMAIL=you@example.com

# ===== Umami =====
UMAMI_POSTGRES_PASSWORD=<openssl rand -hex 16>
UMAMI_APP_SECRET=<openssl rand -hex 32>

# ===== OpenClaw =====
OPENCLAW_TELEGRAM_BOT_TOKEN=
OPENCLAW_GATEWAY_TOKEN=<openssl rand -hex 24>

# ===== Obsidian Vault 경로 =====
VAULT_PATH=/home/ubuntu/vault
