# openglg-config environment variables
# Copy to .env and fill in your values: cp .env.example .env

# ===== Domain =====
# Gateway — choose per service (see README "Gateway"):
#   OPTION A: Caddy + Authelia (path-based, uses DOMAIN below)
#   OPTION B: Cloudflare Tunnel + Access (free; uses per-service hostnames +
#             TUNNEL_TOKEN). metabase/n8n default to B in this repo's compose.
DOMAIN=example.com
ALLOWED_DOMAIN=example.com

# ===== PostgreSQL =====
POSTGRES_PASSWORD=CHANGE_ME
METABASE_DB_PASSWORD=CHANGE_ME
MATTERMOST_DB_PASSWORD=CHANGE_ME
FORGE_DB_PASSWORD=CHANGE_ME

# ===== Metabase =====
# OPTION A (Caddy): served at https://<DOMAIN>/metabase — set MB_SITE_URL to the
#   /metabase form in metabase/docker-compose.yml; METABASE_HOSTNAME unused.
# OPTION B (Cloudflare Tunnel): set METABASE_HOSTNAME and map it to metabase:3000.
METABASE_HOSTNAME=metabase.example.com
METABASE_SECRET_KEY=CHANGE_ME_MIN_16_CHARS

# ===== n8n =====
# n8n needs its own hostname (no working sub-path mode). OPTION A: Caddy subdomain
# block (n8n.DOMAIN). OPTION B: Cloudflare Tunnel. Either way set the hostname here.
# Dedicated DB, own login + JWT.
N8N_HOSTNAME=n8n.example.com
N8N_DB_PASSWORD=CHANGE_ME
N8N_ENCRYPTION_KEY=CHANGE_ME            # openssl rand -hex 32 — keep constant forever
N8N_USER_MANAGEMENT_JWT_SECRET=CHANGE_ME  # openssl rand -hex 32 — pin to avoid logout-on-recreate
GENERIC_TIMEZONE=UTC                    # Cron / Schedule node timezone

# ===== Cloudflare Tunnel ===== (Gateway OPTION B only)
# Zero Trust → Networks → Tunnels → (your tunnel) → token. Never commit the real value.
TUNNEL_TOKEN=

# ===== Remark42 =====
REMARK42_SECRET=CHANGE_ME
REMARK42_SITE=garden
REMARK42_ALLOWED_HOSTS=comments.example.com,garden.example.com
REMARK42_GITHUB_CID=
REMARK42_GITHUB_CSEC=
REMARK42_GOOGLE_CID=
REMARK42_GOOGLE_CSEC=
REMARK42_ADMIN_SHARED_ID=
REMARK42_ADMIN_EMAIL=you@example.com

# ===== Umami =====
UMAMI_POSTGRES_PASSWORD=CHANGE_ME
UMAMI_APP_SECRET=CHANGE_ME

# ===== OpenClaw =====
OPENCLAW_TELEGRAM_BOT_TOKEN=
OPENCLAW_GATEWAY_TOKEN=CHANGE_ME

# ===== Pomerium =====
# See pomerium/config.yaml.template for OAuth setup
POMERIUM_DEBUG=false
