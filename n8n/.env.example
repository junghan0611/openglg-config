# n8n — environment variables
#
# Real .env lives next to docker-compose.yml and is gitignored. Most operators
# keep these in the root .env and symlink this dir's .env there (.env -> ../.env);
# Docker Compose reads only the .env in its own directory.

# Public hostname for n8n, exposed via Cloudflare Tunnel (see cloudflare-tunnel/).
# Map this hostname to http://n8n:5678 in the Cloudflare dashboard.
N8N_HOSTNAME=n8n.example.com

# Timezone for Cron / Schedule nodes (default UTC if unset).
GENERIC_TIMEZONE=UTC

# PostgreSQL password for the dedicated n8n database (n8n-db service).
# Generate: openssl rand -hex 16
N8N_DB_PASSWORD=

# Credentials encryption key — keep constant forever, or saved credentials break.
# Generate: openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# User-management JWT secret — pin it, or every recreate logs all users out.
# Generate: openssl rand -hex 32
N8N_USER_MANAGEMENT_JWT_SECRET=

# Optional — override docker-data location (default ~/docker-data).
# DATA_DIR=/var/lib/openglg
