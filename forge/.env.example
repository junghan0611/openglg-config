# Forgejo — environment variables
#
# Real .env lives next to docker-compose.yml and is gitignored.
#
# Generate the DB password:
#   openssl rand -base64 32 | tr -d '/+=' | head -c 32
#
# After filling in:
#   docker compose up -d
#   → first boot creates /data/forgejo/conf/app.ini via the setup wizard.
#   → visit https://<DOMAIN>/forge/ and complete the wizard (see README.md).

# PostgreSQL password for the forge-db container.
FORGE_DB_PASSWORD=

# Optional — override docker-data location (default ~/docker-data).
# DATA_DIR=/var/lib/openglg
