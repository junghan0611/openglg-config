# Forgejo — environment variables
#
# Real .env lives next to docker-compose.yml and is gitignored.
#
# Generate the DB password:
#   openssl rand -base64 32 | tr -d '/+=' | head -c 32
#
# After filling in:
#   docker compose up -d
#   → first boot creates /data/forgejo/conf/app.ini via the setup wizard.
#   → visit https://<DOMAIN>/forge/ and complete the wizard (see README.md).

# Domain Caddy serves on (matches root .env DOMAIN).
# Used by FORGEJO__server__DOMAIN, FORGEJO__server__ROOT_URL, and the
# webhook allow-list below.
DOMAIN=example.com

# PostgreSQL password for the forge-db container.
# Generate: openssl rand -base64 32 | tr -d '/+=' | head -c 32
FORGE_DB_PASSWORD=

# Optional — override docker-data location (default ~/docker-data).
# Git repositories grow over time; point at a larger partition if needed.
# DATA_DIR=/var/lib/openglg

# Outbound webhook delivery is restricted by Forgejo's
# [webhook] ALLOWED_HOST_LIST setting. docker-compose.yml ships
#   FORGEJO__webhook__ALLOWED_HOST_LIST=private,loopback,${DOMAIN}
# which lets Forgejo POST back into the operator's own host (e.g.
# /openclaw/hooks/forgejo) without opening the whole internet.
# To deliver webhooks to a different host (sibling, mirror), edit that
# line in docker-compose.yml — add the exact hostname, comma-separated.
# Never use `external` unless you really mean "any host on the internet."
# Apply with: docker compose up -d forge   (env changes require recreate)
